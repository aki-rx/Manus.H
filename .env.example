# ============================================================
# Open WebUI Configuration — Non-Secret Defaults
# ============================================================
# These are safe to store on disk. Override any of them by
# exporting the variable in your terminal before running
# docker compose up.
#
# SECRETS (API keys, passwords) are NOT stored here.
# They must be exported in your terminal session:
#
#   export OPENAI_API_KEY="sk-or-..."
#   export WEBUI_SECRET_KEY="$(openssl rand -hex 32)"
#   export WEBUI_ADMIN_PASSWORD="your-strong-password"
#   docker compose up -d
#
# Or use the start.sh script which prompts for them.
# ============================================================

WEBUI_NAME=AI Chat
WEBUI_URL=http://localhost:3000
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_NAME=Admin
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
DEFAULT_MODELS=openrouter/auto
DEFAULT_PINNED_MODELS=openrouter/auto
TASK_MODEL_EXTERNAL=openrouter/auto
