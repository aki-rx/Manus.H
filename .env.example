# ============================================================
# Open WebUI Configuration
# ============================================================
# Copy this file to .env and fill in your values before running
# docker compose up -d
# ============================================================

# --- General ---
WEBUI_NAME=AI Chat
WEBUI_URL=http://localhost:3000
WEBUI_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY

# --- Admin Account (auto-created on first launch) ---
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WEBUI_ADMIN_NAME=Admin

# --- Signup ---
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending

# --- Ollama ---
# OLLAMA_BASE_URL is set in docker-compose.yml
# If you have a remote Ollama instance, override it here:
# OLLAMA_BASE_URL=http://your-ollama-host:11434

# --- OpenRouter (via OpenAI-compatible API) ---
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# --- Default Model (OpenRouter auto-routing) ---
DEFAULT_MODELS=openrouter/auto
DEFAULT_PINNED_MODELS=openrouter/auto

# --- Task Models (for title generation, search queries, etc.) ---
TASK_MODEL_EXTERNAL=openrouter/auto

# --- Features ---
ENABLE_TITLE_GENERATION=true
ENABLE_TAGS_GENERATION=true

# --- Locale ---
DEFAULT_LOCALE=en
